# Base de datos Postgres (Railway inyecta ${{Postgres.DATABASE_URL}} en prod)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Resend (emails transaccionales)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# Mercado Pago
MP_ACCESS_TOKEN="TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000"
MP_WEBHOOK_SECRET="tu_secret_de_webhook_desde_panel_mp"

# App
APP_URL="https://aliciamoralescoach.com"
ADMIN_EMAIL="coaching@aliciamorales.cl"

# ==========================================================================
# Moodle (Hito 1 — LMS). Estas variables NO viven aquí en prod:
#  - Las MOODLE_DB_* / MOODLE_ADMIN_* / MOODLE_SITE_URL / MOODLE_SSLPROXY /
#    MOODLE_SMTP_* se configuran en el servicio "moodle" de Railway.
#  - Las MOODLE_WS_* / MOODLE_DEFAULT_ROLE_ID / ADMIN_ENROL_SECRET se usan en
#    Next.js (integración -> Moodle) y van en el servicio Next.js de Railway.
# Se documentan aquí como referencia.
# ==========================================================================

# --- Servicio Moodle (LMS) ---
MOODLE_DB_HOST=                       # en Railway: ${{mariadb.RAILWAY_PRIVATE_DOMAIN}}
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=                   # en Railway: ${{mariadb.MARIADB_PASSWORD}}
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=
MOODLE_ADMIN_EMAIL=
MOODLE_SITE_URL=https://cursos.aliciamoralescoach.com
MOODLE_SSLPROXY=yes

# --- SMTP de Moodle (vía Resend) — se configura en el Commit 3 ---
MOODLE_SMTP_HOST=smtp.resend.com
MOODLE_SMTP_USER=resend
MOODLE_SMTP_PASSWORD=                 # = RESEND_API_KEY

# --- Integración Next.js -> Moodle Web Services (Commits 4, 6 y 7) ---
MOODLE_WS_URL=https://cursos.aliciamoralescoach.com/webservice/rest/server.php
MOODLE_WS_TOKEN=
MOODLE_DEFAULT_ROLE_ID=5

# --- Protección del endpoint admin B2B (Commit 7) ---
# El endpoint POST /api/admin/enrol-b2b exige el header  x-admin-secret: <valor>
ADMIN_ENROL_SECRET=

# Remitente del correo de acceso (Commit 7). Mientras Resend esté en sandbox usa
# onboarding@resend.dev (solo entrega al email dueño de la cuenta). Al verificar
# un dominio en Resend, cambiar a:  noreply@<dominio-verificado>
EMAIL_FROM="Escuela de Competencias Aplicadas <onboarding@resend.dev>"

# ==========================================================================
# Certificación digital con QR
# ==========================================================================

# Clave para firmar las cookies de sesión del panel admin (mínimo 32 chars).
# Generar con: openssl rand -hex 32
ADMIN_SESSION_SECRET="cambiar_en_produccion_32_chars_min"

# Credenciales del usuario admin (usadas solo por scripts/seed-admin.ts).
# Distintas de ADMIN_EMAIL (que es el destinatario de notificaciones de venta).
CERT_ADMIN_EMAIL="alicia@aliciamoralescoach.com"
CERT_ADMIN_PASSWORD="cambiar_al_primer_login"
CERT_ADMIN_NOMBRE="Alicia Morales"

# URL pública del sitio (se usa para armar la URL del QR de verificación).
NEXT_PUBLIC_SITE_URL="https://aliciamoralescoach.com"
