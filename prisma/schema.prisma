generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String   @db.Text
  priceClp    Int
  durationMin Int
  imageUrl    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id String @id @default(cuid())

  buyerName  String
  buyerEmail String
  buyerPhone String
  buyerRut   String

  totalClp Int
  currency String @default("CLP")

  status OrderStatus @default(PENDING)

  mpPreferenceId String? @unique
  mpPaymentId    String? @unique
  mpStatus       String?

  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  items OrderItem[]

  @@index([buyerEmail])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int    @default(1)
  unitPriceClp  Int
  titleSnapshot String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

enum OrderStatus {
  PENDING
  PAID
  REJECTED
  REFUNDED
  EXPIRED
}

// ===========================================================================
// Moodle — Hito 1 (cursos, clientes B2B y enrolamientos). Modelos NUEVOS.
// ===========================================================================

model Curso {
  id             String   @id @default(cuid())
  moodleCourseId Int      @unique
  nombre         String
  modalidad      Modalidad
  creadoEn       DateTime @default(now())
  enrolamientos  Enrolamiento[]
  emisiones      Emision[]
}

model ClienteB2B {
  id             String   @id @default(cuid())
  nombreEmpresa  String
  rut            String?
  contactoEmail  String
  contactoNombre String?
  creadoEn       DateTime @default(now())
  enrolamientos  Enrolamiento[]
}

model Enrolamiento {
  id           String   @id @default(cuid())
  cursoId      String
  curso        Curso    @relation(fields: [cursoId], references: [id])
  clienteB2BId String?
  clienteB2B   ClienteB2B? @relation(fields: [clienteB2BId], references: [id])
  alumnoEmail  String
  alumnoNombre String
  moodleUserId Int?
  origen       OrigenEnrolamiento
  estado       EstadoEnrolamiento @default(PENDIENTE)
  creadoEn     DateTime @default(now())
  correoEnviadoEn DateTime?   // null = correo pendiente de enviar; con fecha = enviado

  @@unique([cursoId, alumnoEmail])
}

enum Modalidad {
  B2B
  INDIVIDUAL
}

enum OrigenEnrolamiento {
  B2B
  INDIVIDUAL
}

enum EstadoEnrolamiento {
  PENDIENTE
  ENROLADO
  ERROR
}

// ===========================================================================
// Certificación digital con QR — Hito Certificados. Modelos NUEVOS.
// ===========================================================================

model AdminUser {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  nombre        String
  activo        Boolean  @default(true)
  ultimoLoginEn DateTime?
  creadoEn      DateTime @default(now())

  emisiones Emision[]
}

model PlantillaCertificado {
  id           String   @id @default(cuid())
  nombre       String   @unique
  descripcion  String?
  version      Int      @default(1)
  activa       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  certificados Certificado[]
  emisiones    Emision[]
}

model Emision {
  id              String   @id @default(cuid())
  cursoId         String
  curso           Curso    @relation(fields: [cursoId], references: [id])
  plantillaId     String
  plantilla       PlantillaCertificado @relation(fields: [plantillaId], references: [id])
  adminUserId     String
  adminUser       AdminUser @relation(fields: [adminUserId], references: [id])
  cantidadTotal   Int
  nombreArchivo   String?
  notas           String?  @db.Text
  creadaEn        DateTime @default(now())
  certificados    Certificado[]

  @@index([cursoId])
  @@index([creadaEn])
}

model Certificado {
  id              String   @id @default(cuid())
  codigo          String   @unique
  emisionId       String
  emision         Emision  @relation(fields: [emisionId], references: [id])
  plantillaId     String
  plantilla       PlantillaCertificado @relation(fields: [plantillaId], references: [id])

  alumnoNombre    String
  alumnoRut       String
  alumnoEmail     String

  cursoNombre     String
  fechaEmision    DateTime
  fechaAprobacion DateTime
  horasCurso      Int

  hashIntegridad  String

  estado          EstadoCertificado @default(VALIDO)
  motivoAnulacion String?
  anuladoEn       DateTime?
  anuladoPorId    String?

  emailEnviadoEn  DateTime?
  creadoEn        DateTime @default(now())

  verificaciones  VerificacionLog[]

  @@index([alumnoRut])
  @@index([alumnoEmail])
  @@index([estado])
  @@index([emisionId])
}

model VerificacionLog {
  id            String   @id @default(cuid())
  certificadoId String
  certificado   Certificado @relation(fields: [certificadoId], references: [id])
  ip            String?
  userAgent     String?
  verificadoEn  DateTime @default(now())

  @@index([certificadoId])
  @@index([verificadoEn])
}

enum EstadoCertificado {
  VALIDO
  ANULADO
}
